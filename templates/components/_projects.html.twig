<section id="projects" class="mt-12 lg:mt-16 max-w-3xl mx-auto lg:mx-0">
    <h2 class="text-3xl lg:text-4xl font-bold mb-6 lg:mb-8" data-trans="sections.projects">{{ 'sections.projects'|trans }}</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {% for project in projects %}
            <div class="group relative overflow-hidden rounded-xl shadow-md hover:shadow-lg transition-all duration-500 
                        flex flex-col bg-gradient-to-br from-primary/20 to-base-300/90 border border-base-content/10">
                <!-- Background Image with overlay -->
                <div class="absolute inset-0 z-0 opacity-40 group-hover:opacity-60 group-hover:scale-105 transition-all duration-300">
                    <img src="{{ asset('images/' ~ project.image) }}" 
                         alt="{{ project.title_key|trans }}" 
                         class="w-full h-full object-cover">
                    <!-- Dark overlay -->
                    <div class="absolute inset-0 bg-base-100/60"></div>
                </div>

                <!-- Content Wrapper -->
                <div class="relative z-10 flex flex-col flex-grow p-4 pt-2">
                    <!-- Project Title -->
                    <div class="text-center w-fit mx-auto mb-1">
                        <h3 class="text-lg font-bold w-fit bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent" data-trans="{{ project.title_key }}">
                            {{ project.title_key|trans }}
                        </h3>
                    </div>

                    <!-- Description -->
                    <p class="text-sm leading-tight mb-3 text-justify" data-trans="{{ project.description_key }}">
                        {{ project.description_key|trans }}
                    </p>

                    <!-- Spacer to push badges and links to bottom -->
                    <div class="flex-grow"></div>

                    <!-- Technologies -->
                    <div class="flex flex-wrap gap-1 mb-2">
                        {% for tech in project.technologies %}
                            <div class="badge badge-md px-1.5 py-1 bg-{{ tech.color_bg }} text-{{ tech.color_text }} hover:bg-{{ tech.color_hover }} transition-colors border-none">
                                {% if tech.icon is defined %}
                                    <i class="{{ tech.icon }} mr-0.5 text-xs"></i>
                                {% else %}
                                    <img src="{{ asset('images/' ~ tech.image) }}" alt="{{ tech.label_key|trans }}" class="w-2.5 h-2.5 mr-1">
                                {% endif %}
                                <span data-trans="{{ tech.label_key }}">{{ tech.label_key|trans }}</span>
                            </div>
                        {% endfor %}
                    </div>

                    <!-- Links -->
                    <div class="flex flex-wrap gap-1.5">
                        {% if project.github %}
                            <a href="{{ project.github }}" target="_blank" rel="noopener noreferrer" 
                               class="btn btn-xs gap-1.5 bg-base-content/5 hover:bg-base-content/10 text-base-content border-0 transition-all duration-300">
                                <i class="fa-brands fa-github"></i>
                                <span class="text-[10px]" data-trans="projects.links.view_code">{{ 'projects.links.view_code'|trans }}</span>
                            </a>
                        {% endif %}
                        {% if project.website %}
                            <a href="{{ project.website }}" target="_blank" rel="noopener noreferrer" 
                               class="btn btn-xs gap-1.5 bg-primary hover:bg-primary/80 text-primary-content border-0 transition-all duration-300">
                                <i class="fa-solid fa-globe"></i>
                                <span class="text-[10px]" data-trans="projects.links.visit_website">{{ 'projects.links.visit_website'|trans }}</span>
                            </a>
                        {% endif %}
                        {% if project.demo %}
                            <a href="{{ project.demo }}" target="_blank" rel="noopener noreferrer" 
                               class="btn btn-xs gap-1.5 bg-emerald-500/10 hover:bg-emerald-500/20 text-emerald-500 border-0 transition-all duration-300">
                                <i class="fa-solid fa-arrow-up-right-from-square"></i>
                                <span class="text-[10px]" data-trans="projects.links.live_demo">{{ 'projects.links.live_demo'|trans }}</span>
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
</section>
